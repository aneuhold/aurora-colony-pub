{
  "name": "aurora-colony-pub",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "dev": "pnpm --filter ./site dev",
    "build": "pnpm -r --parallel build",
    "build:site": "pnpm --filter ./site build",
    "build:workers": "pnpm -r --parallel --filter \"./workers/*\" build",
    "preview": "pnpm --filter ./site preview",
    "lint": "eslint --cache",
    "check": "pnpm -r --parallel check",
    "test": "pnpm -r --parallel test",
    "deploy:workers": "pnpm -r --parallel --filter \"./workers/*\" deploy",
    "upgrade:deps": "pnpm -r exec pnpm up --latest && pnpm up --latest"
  },
  "devDependencies": {
    "@aneuhold/eslint-config": "^2.0.5",
    "@cloudflare/vitest-pool-workers": "^0.12.4",
    "@types/node": "^25.6.0",
    "astro-eslint-parser": "^1.2.2",
    "concurrently": "^9.2.1",
    "eslint": "^10.0.0",
    "eslint-plugin-astro": "^1.3.1",
    "prettier": "^3.8.3",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-svelte": "^3.5.1",
    "typescript": "^6.0.3"
  }
}
