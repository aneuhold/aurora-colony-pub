---
import FacebookFeed from '$components-svelte/FacebookFeed';
import Container from './ui/Container.astro';
import Heading from './ui/Heading.astro';
import Section from './ui/Section.astro';
---

<!-- Heritage wood band backing the feed (real walnut board owned by the Section 'wood'
     variant) — the menu's "planks under torn paper" stack. Posts render as torn-paper
     scraps on top inside the island. -->
<Section background="wood">
  <Container size="wide">
    <div class="flex flex-wrap items-baseline justify-between gap-3">
      <Heading level={2} class="text-surface-wood-foreground">Lately at the pub.</Heading>
      <a
        href="https://www.facebook.com/theauroracolonypub/"
        target="_blank"
        rel="noopener noreferrer"
        class="font-display text-sm uppercase tracking-[0.18em] text-surface-wood-foreground/90 underline-offset-4 transition-colors duration-snap ease-soft hover:text-surface-wood-foreground hover:underline"
      >
        Follow on Facebook →
      </a>
    </div>
    <div class="mt-10">
      <FacebookFeed client:visible />
    </div>
  </Container>
</Section>
