---
import { getCollection } from 'astro:content';
import MasonryImages from '$components-astro/MasonryImages.astro';
import Container from '$components-astro/ui/Container.astro';
import Heading from '$components-astro/ui/Heading.astro';
import Section from '$components-astro/ui/Section.astro';
import galleryService from './Gallery.service';

interface Props {
  limit?: number;
  heading?: string;
}

const { limit, heading = 'From the room.' } = Astro.props;

const sorted = galleryService.sortEntries(await getCollection('gallery'));
const entries = typeof limit === 'number' ? sorted.slice(0, limit) : sorted;
const images = entries.map((entry) => ({ photo: entry.data.photo, alt: entry.data.alt }));
---

{
  images.length > 0 && (
    <Section id="gallery">
      <Container size="wide">
        <Heading level={2}>{heading}</Heading>
        <div class="mt-10">
          <MasonryImages images={images} />
        </div>
      </Container>
    </Section>
  )
}
