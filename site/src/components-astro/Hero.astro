---
interface Props {
  title: string;
  tagline?: string;
}

const { title, tagline } = Astro.props;
---

<section class="hero">
  <h1>{title}</h1>
  {tagline && <p>{tagline}</p>}
</section>

<style>
  .hero {
    padding: 4rem 1.5rem;
    text-align: center;
  }
  .hero h1 {
    font-size: clamp(2rem, 6vw, 3.5rem);
    margin: 0 0 0.5rem;
  }
  .hero p {
    color: var(--muted-foreground);
    margin: 0;
  }
</style>
