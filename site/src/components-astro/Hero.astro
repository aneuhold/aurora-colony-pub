---
import { Image } from 'astro:assets';
import Button from '$components-astro/ui/Button.astro';
import Container from '$components-astro/ui/Container.astro';
import Heading from '$components-astro/ui/Heading.astro';
import Section from '$components-astro/ui/Section.astro';
import OpenNowChip from '$components-svelte/OpenNowChip';
import TodayHours from '$components-svelte/TodayHours';
import { globalConstants } from '$util/globalConstants';
import pubContentService from '$util/PubContent.service';
import DoorDashIcon from '../assets/icons/doordash.svg';
import Logo from '../assets/logo.svg';

const heroPhoto = globalConstants.mediaUrl('interior-red-room.jpg');

interface Props {
  title: string;
  tagline?: string;
}

const { title, tagline } = Astro.props;

const hoursEntry = await pubContentService.hours();
const contactEntry = await pubContentService.contact();
const { orderUrl } = contactEntry.data;
---

<Section padding="hero" class="relative flex min-h-[88svh] items-end overflow-hidden pt-28 md:pt-32">
  <Image
    src={heroPhoto}
    alt="Red wood-paneled room with neon signs, vinyl booth seating, and patrons in the background."
    inferSize
    widths={[768, 1280, 1920, 2560]}
    sizes="100vw"
    loading="eager"
    fetchpriority="high"
    class="absolute inset-0 h-full w-full object-cover object-bottom"
  />
  <div
    class="absolute inset-0 bg-linear-to-t from-foreground/90 via-foreground/50 to-foreground/10"
  >
  </div>
  <!-- Warm tungsten glow pooling up from the bottom — makes the photo read lamp-lit
       and lifts the type off the image. Kept subtle so it warms without tinting. -->
  <div class="absolute inset-0 bg-linear-to-t from-primary/18 via-transparent to-transparent"></div>

  <Logo
    aria-hidden="true"
    class="absolute left-6 top-8 z-10 h-16 w-auto text-background md:left-12 md:top-12 md:h-20"
  />

  <Container size="wide" class="relative px-6 pb-16 text-background md:pb-24">
    <div class="animate-fade-in">
      <Heading level={0}>{title}</Heading>
      {tagline && <p class="mt-3 font-display text-xl text-background/85 md:text-2xl">{tagline}</p>}
      <p class="mt-4 font-display text-2xl text-background/90 md:text-3xl">
        Bring the whole family in for <span class="font-script text-background">a great meal.</span>
      </p>
      <div
        class="mt-8 flex flex-wrap items-center gap-x-3 gap-y-2 font-body text-sm text-background/85 md:text-base"
      >
        <OpenNowChip weekly={hoursEntry.data.weekly} client:idle />
        <span aria-hidden="true">·</span>
        <span>Today <TodayHours weekly={hoursEntry.data.weekly} client:idle /></span>
        <span aria-hidden="true">·</span>
        <span>{globalConstants.cityLabel}</span>
      </div>
      <div class="mt-8 flex flex-wrap items-center gap-3">
        <Button variant="accent" href="/menu">See the menu</Button>
        <Button variant="inverted" href="/contact#map">Get directions</Button>
        {
          orderUrl && (
            <Button
              variant="primary"
              href={orderUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="gap-2"
            >
              <DoorDashIcon aria-hidden="true" class="h-4 w-4" />
              <span>Order now</span>
            </Button>
          )
        }
      </div>
    </div>
  </Container>
</Section>
