---
import { getEntry } from 'astro:content';
import { globalConstants } from '$util/globalConstants';
import pubMapService from '$util/PubMap/PubMap.service';

const entry = await getEntry('contact', 'contact');
if (!entry) {
  throw new Error('Missing contact content entry');
}
const { phone, email } = entry.data;
const telHref = `tel:${phone.replace(/[^\d+]/g, '')}`;
---

<address class="not-italic font-body leading-relaxed">
  <p>{globalConstants.fullAddress}</p>
  <p class="mt-1">
    <a
      href={pubMapService.directionsUrl}
      target="_blank"
      rel="noopener noreferrer"
      class="text-primary underline-offset-4 transition-colors duration-snap ease-soft hover:underline"
    >
      Get directions →
    </a>
  </p>
  <p class="mt-2">
    <a
      href={telHref}
      class="text-primary underline-offset-4 transition-colors duration-snap ease-soft hover:underline"
    >
      {phone}
    </a>
  </p>
  <p>
    <a
      href={`mailto:${email}`}
      class="text-primary underline-offset-4 transition-colors duration-snap ease-soft hover:underline"
    >
      {email}
    </a>
  </p>
</address>
