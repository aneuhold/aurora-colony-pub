---
import { getEntry, render } from 'astro:content';
import Container from '$components-astro/ui/Container.astro';
import Section from '$components-astro/ui/Section.astro';

const entry = await getEntry('about', 'about');
if (!entry) {
  throw new Error('Missing about content entry');
}
const { Content } = await render(entry);

interface Fact {
  headline: string;
  body: string;
}

const facts: Fact[] = [
  {
    headline: 'Since 2015',
    body: 'Corey & Janae Barton — the latest in a long line of proprietors keeping the lights on.'
  },
  {
    headline: 'Built in the 1930s',
    body: 'Original wood frame on old 99E, tin roof, sloping concrete floors that still slope.'
  },
  {
    headline: 'Original meat-locker door',
    body: 'Still behind the bar, still keeping our kegs and bottles cold.'
  }
];
---

<Section>
  <Container size="narrow">
    <div
      class="text-lg leading-relaxed text-foreground/80 [&_a]:text-primary [&_img]:h-auto [&_img]:max-w-full [&_img]:rounded-md [&_p:first-of-type::first-letter]:float-left [&_p:first-of-type::first-letter]:mr-3 [&_p:first-of-type::first-letter]:mt-1 [&_p:first-of-type::first-letter]:font-display [&_p:first-of-type::first-letter]:text-6xl [&_p:first-of-type::first-letter]:leading-[0.85] [&_p:first-of-type::first-letter]:text-foreground [&_p:not(:first-of-type)]:mt-5"
    >
      <Content />
    </div>

    <div class="reveal mt-16 grid gap-10 border-t border-foreground/10 pt-10 md:grid-cols-3">
      {
        facts.map((fact) => (
          <div>
            <p class="font-display text-3xl tracking-tight text-foreground md:text-4xl">
              {fact.headline}
            </p>
            <p class="mt-2 text-foreground/60">{fact.body}</p>
          </div>
        ))
      }
    </div>
  </Container>
</Section>
