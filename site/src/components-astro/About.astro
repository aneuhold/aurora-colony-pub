---
import { getEntry, render } from 'astro:content';

const entry = await getEntry('about', 'about');
if (!entry) {
  throw new Error('Missing about content entry');
}
const { Content } = await render(entry);
---

<section class="about">
  <h2>{entry.data.heading}</h2>
  <div class="about__body">
    <Content />
  </div>
</section>

<style>
  .about {
    padding: 2rem 1.5rem;
    max-width: 48rem;
    margin: 0 auto;
  }
  .about h2 {
    color: var(--foreground);
    font-size: clamp(1.5rem, 4vw, 2rem);
    margin: 0 0 1rem;
  }
  .about__body {
    color: var(--muted-foreground);
    line-height: 1.6;
  }
  .about__body :global(a) {
    color: var(--primary);
  }
  .about__body :global(img) {
    max-width: 100%;
    height: auto;
    border-radius: 0.5rem;
  }
</style>
