---
import { getEntry, render } from 'astro:content';
import Container from '$components-astro/ui/Container.astro';
import Heading from '$components-astro/ui/Heading.astro';
import Section from '$components-astro/ui/Section.astro';

const entry = await getEntry('about', 'about');
if (!entry) {
  throw new Error('Missing about content entry');
}
const { Content } = await render(entry);
---

<Section class="reveal">
  <Container size="narrow">
    <Heading level={2}>{entry.data.heading}</Heading>
    <div class="about-body mt-6 leading-relaxed text-foreground/80">
      <Content />
    </div>
  </Container>
</Section>

<style>
  .about-body :global(a) {
    color: var(--color-primary);
  }
  .about-body :global(img) {
    max-width: 100%;
    height: auto;
    border-radius: 0.5rem;
  }
</style>
