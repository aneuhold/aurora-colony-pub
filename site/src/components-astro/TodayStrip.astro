---
import { getEntry } from 'astro:content';
import Container from '$components-astro/ui/Container.astro';
import Section from '$components-astro/ui/Section.astro';
import dateTimeService from '$util/DateTime.service';

const hoursEntry = await getEntry('hours', 'hours');
if (!hoursEntry) {
  throw new Error('Missing hours content entry');
}
const locationEntry = await getEntry('locationContact', 'location-contact');
if (!locationEntry) {
  throw new Error('Missing locationContact content entry');
}

const now = new Date();
const todayIdx = now.getDay();
const todayLabel = dateTimeService.shortDayLabel(now);

const todayRow =
  dateTimeService.rowForDay(hoursEntry.data.weekly, todayIdx) ?? hoursEntry.data.weekly[0];

const { address, phone } = locationEntry.data;
const telHref = `tel:${phone.replace(/[^\d+]/g, '')}`;
const mapsHref = `https://www.google.com/maps/?q=${encodeURIComponent(address)}`;
const { happyHour } = hoursEntry.data;
const isHappyHourDay =
  happyHour.label.includes(todayLabel) || happyHour.label.toLowerCase().includes('every');

const todayHoursLine = `${todayRow.open} – ${todayRow.close}`;
const happyHourLine = isHappyHourDay
  ? `Happy hour ${happyHour.start} – ${happyHour.end}`
  : null;
---

<Section padding="tight" background="muted" class="border-y border-foreground/10">
  <Container size="wide">
    <div class="grid gap-8 md:grid-cols-3 md:gap-12">
      <div>
        <p class="font-display text-sm uppercase tracking-[0.18em] text-foreground/60">Today</p>
        <p class="mt-2 text-xl text-foreground md:text-2xl">{todayHoursLine}</p>
        {happyHourLine && <p class="mt-1 text-foreground/70">{happyHourLine}</p>}
      </div>
      <div>
        <p class="font-display text-sm uppercase tracking-[0.18em] text-foreground/60">Find us</p>
        <p class="mt-2 text-xl leading-snug text-foreground md:text-2xl">{address}</p>
        <a
          href={mapsHref}
          target="_blank"
          rel="noopener noreferrer"
          class="mt-2 inline-block text-primary underline-offset-4 transition-colors duration-snap ease-soft hover:underline"
        >
          Get directions
        </a>
      </div>
      <div>
        <p class="font-display text-sm uppercase tracking-[0.18em] text-foreground/60">Call</p>
        <p class="mt-2">
          <a
            href={telHref}
            class="font-display text-3xl tracking-tight text-foreground transition-colors duration-snap ease-soft hover:text-primary md:text-4xl"
          >
            {phone}
          </a>
        </p>
      </div>
    </div>
  </Container>
</Section>
