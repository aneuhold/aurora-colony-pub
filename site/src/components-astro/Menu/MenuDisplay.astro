---
import { Image } from 'astro:assets';
import { getCollection, type CollectionEntry } from 'astro:content';
import Heading from '$components-astro/ui/Heading.astro';
import type { MenuCategory } from './menuTypes';

type CategoryDisplay = {
  id: MenuCategory;
  label: string;
};

const categoryOrder: CategoryDisplay[] = [
  { id: 'main', label: 'Main menu' },
  { id: 'breakfast', label: 'Breakfast' },
  { id: 'kids', label: 'Kids' },
  { id: 'happy-hour', label: 'Happy hour' }
];

const all = (await getCollection('menuImages')).sort((a, b) => a.data.order - b.data.order);

const groupedByCategory = new Map<MenuCategory, CollectionEntry<'menuImages'>[]>();
for (const entry of all) {
  const list = groupedByCategory.get(entry.data.category) ?? [];
  list.push(entry);
  groupedByCategory.set(entry.data.category, list);
}

const visibleCategories = categoryOrder.filter(
  (cat) => (groupedByCategory.get(cat.id) ?? []).length > 0
);

let globalIndex = 0;
---

<div class="flex flex-col gap-20">
  {
    visibleCategories.map((category, catIdx) => {
      const entries = groupedByCategory.get(category.id) ?? [];
      const eyebrow = `Menu ${String(catIdx + 1).padStart(2, '0')}`;
      const isLast = catIdx === visibleCategories.length - 1;
      return (
        <section id={category.id} class="scroll-mt-24">
          <p class="font-display text-sm uppercase tracking-[0.2em] text-accent">{eyebrow}</p>
          <Heading level={2} class="mt-2 text-foreground/90">
            {category.label}
          </Heading>
          <div class="mt-8 flex flex-col gap-8">
            {entries.map((entry) => {
              const isFirst = globalIndex === 0;
              globalIndex += 1;
              return (
                <a
                  href={entry.data.image.src}
                  target="_blank"
                  rel="noopener noreferrer"
                  aria-label={`Open full size: ${entry.data.title}`}
                  class="block overflow-hidden rounded-lg border border-foreground/10 shadow-[0_1px_0_oklch(0.2_0.012_60/0.04)]"
                >
                  <figure class="m-0">
                    <Image
                      src={entry.data.image}
                      alt={entry.data.title}
                      widths={[640, 960, 1280]}
                      sizes="(min-width: 768px) 768px, 100vw"
                      loading={isFirst ? 'eager' : 'lazy'}
                      class="block h-auto w-full"
                    />
                  </figure>
                </a>
              );
            })}
            {isLast && (
              <aside class="mt-2 text-sm italic text-foreground/60">
                Consuming raw or under-cooked eggs and meats may increase your risk of foodborne
                illness — especially if you suffer from a medical condition.
              </aside>
            )}
          </div>
        </section>
      );
    })
  }
</div>
