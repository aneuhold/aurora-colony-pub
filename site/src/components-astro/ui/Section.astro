---
type Background = 'default' | 'muted' | 'primary' | 'wood';
type Padding = 'default' | 'tight' | 'hero';

interface Props {
  background?: Background;
  padding?: Padding;
  as?: keyof HTMLElementTagNameMap;
  class?: string;
  id?: string;
}

const {
  background = 'default',
  padding = 'default',
  as = 'section',
  class: className,
  id
} = Astro.props as Props;

const Tag = as;

const backgroundClass: Record<Background, string> = {
  default: '',
  muted: 'bg-foreground/5',
  primary: 'bg-primary text-primary-foreground',
  // The wood variant owns its surface: a real walnut board tiled at a fixed scale
  // (bg-wood-photo) so the grain reads the same size on every section, plus the cream
  // foreground colour. See bg-wood-photo in tokens.css for the why.
  wood: 'bg-wood-photo text-surface-wood-foreground'
};

const paddingClass: Record<Padding, string> = {
  default: 'px-6 py-16 md:py-24',
  tight: 'px-6 py-10 md:py-14',
  hero: 'px-0 py-0'
};
---

<Tag id={id} class:list={[paddingClass[padding], backgroundClass[background], className]}>
  <slot />
</Tag>
