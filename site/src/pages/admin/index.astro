---
// Standalone admin shell. Imports @sveltia/cms so Astro bundles it through
// Vite — no third-party CDN dependency. We call `init()` explicitly because
// Sveltia's auto-init only fires for inline scripts or a script src ending
// in `/sveltia-cms.js`, neither of which matches Astro's hashed module bundle.
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex,nofollow" />
    <title>Aurora Colony Pub CMS</title>
  </head>
  <body>
    <script>
      import { init } from '@sveltia/cms';

      const CMS_AUTH_BASE_URL = import.meta.env.DEV
        ? 'http://localhost:8790'
        : 'https://aurora-cms-auth.agneuhold.workers.dev';

      // These two keys are internal to @sveltia/cms. They're the localStorage
      // entries Sveltia writes the GitHub OAuth result and the user prefs to.
      // If image uploads stop working after a Sveltia upgrade, check that the
      // key names below still match what Sveltia reads — see
      // node_modules/@sveltia/cms/dist/sveltia-cms.mjs (the `pS` storage
      // helper plus the `cloudflare_r2` apiKey lookup).
      const SVELTIA_USER_KEY = 'sveltia-cms.user';
      const SVELTIA_PREFS_KEY = 'sveltia-cms.prefs';
      const R2_SERVICE_ID = 'cloudflare_r2';

      // Sveltia's OAuth callback (served by the cms-auth Worker) postMessages
      // this exact string prefix back to the opener window when login succeeds.
      // We listen for the same message so we can fetch the R2 secret as soon
      // as the token lands — without waiting for the next page load.
      const SVELTIA_LOGIN_SUCCESS_PREFIX = 'authorization:github:success:';

      const readJson = (storageKey: string): Record<string, unknown> | null => {
        try {
          const raw = localStorage.getItem(storageKey);
          if (!raw) return null;
          const parsed: unknown = JSON.parse(raw);
          if (typeof parsed !== 'object' || parsed === null || Array.isArray(parsed)) return null;
          return parsed as Record<string, unknown>;
        } catch {
          return null;
        }
      };

      const writeJson = (storageKey: string, value: Record<string, unknown>): void => {
        try {
          localStorage.setItem(storageKey, JSON.stringify(value));
        } catch {
          // localStorage write failures (quota, private mode) are non-fatal:
          // Sveltia will fall back to prompting the user for the secret.
        }
      };

      const clearR2Secret = (): void => {
        const prefs = readJson(SVELTIA_PREFS_KEY) ?? {};
        const apiKeys = prefs.apiKeys;
        if (apiKeys && typeof apiKeys === 'object' && !Array.isArray(apiKeys)) {
          delete (apiKeys as Record<string, unknown>)[R2_SERVICE_ID];
          writeJson(SVELTIA_PREFS_KEY, prefs);
        }
      };

      const populateR2Secret = (secretAccessKey: string): void => {
        const prefs = readJson(SVELTIA_PREFS_KEY) ?? {};
        const existing = prefs.apiKeys;
        const apiKeys: Record<string, unknown> =
          existing && typeof existing === 'object' && !Array.isArray(existing)
            ? (existing as Record<string, unknown>)
            : {};
        apiKeys[R2_SERVICE_ID] = secretAccessKey;
        prefs.apiKeys = apiKeys;
        writeJson(SVELTIA_PREFS_KEY, prefs);
      };

      const fetchAndStoreR2Secret = async (ghToken: string): Promise<void> => {
        let response: Response;
        try {
          response = await fetch(`${CMS_AUTH_BASE_URL}/r2-credentials`, {
            headers: { Authorization: `Bearer ${ghToken}` }
          });
        } catch {
          // Network failure — leave any cached secret in place so a
          // previously-working session keeps working offline.
          return;
        }
        if (response.status === 401 || response.status === 403) {
          // The GitHub token Sveltia is holding is no longer valid for our
          // allowlist. Wipe any stale R2 secret so Sveltia re-prompts after
          // the next sign-in.
          clearR2Secret();
          return;
        }
        if (!response.ok) return;
        let body: unknown;
        try {
          body = await response.json();
        } catch {
          return;
        }
        if (
          body !== null &&
          typeof body === 'object' &&
          'secretAccessKey' in body &&
          typeof body.secretAccessKey === 'string'
        ) {
          populateR2Secret(body.secretAccessKey);
        }
      };

      /**
       * Listens for the OAuth-success postMessage Sveltia is also listening
       * for. Fetches the R2 secret as soon as a fresh login completes, so the
       * user can upload immediately without a page refresh. Both listeners
       * (ours + Sveltia's) receive the same event independently.
       */
      const installLoginListener = (): void => {
        const expectedOrigin = new URL(CMS_AUTH_BASE_URL).origin;
        window.addEventListener('message', (event) => {
          if (event.origin !== expectedOrigin) return;
          if (typeof event.data !== 'string') return;
          if (!event.data.startsWith(SVELTIA_LOGIN_SUCCESS_PREFIX)) return;
          let payload: unknown;
          try {
            payload = JSON.parse(event.data.slice(SVELTIA_LOGIN_SUCCESS_PREFIX.length));
          } catch {
            return;
          }
          if (
            payload !== null &&
            typeof payload === 'object' &&
            'token' in payload &&
            typeof payload.token === 'string'
          ) {
            void fetchAndStoreR2Secret(payload.token);
          }
        });
      };

      const start = async (): Promise<void> => {
        // Register before init() so we catch fresh-login postMessages, even
        // ones that fire before our initial `fetchAndStoreR2Secret` settles.
        installLoginListener();

        const user = readJson(SVELTIA_USER_KEY);
        const token = user && typeof user.token === 'string' ? user.token : null;
        if (token) {
          await fetchAndStoreR2Secret(token);
        }
        init();
      };

      void start();
    </script>
  </body>
</html>
