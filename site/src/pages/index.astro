---
import BaseLayout from '../layouts/BaseLayout.astro';
import AboutTeaser from '$components-astro/AboutTeaser.astro';
import FacebookFeedSection from '$components-astro/FacebookFeedSection.astro';
import Gallery from '$components-astro/Gallery';
import Hero from '$components-astro/Hero.astro';
import MenuTeaser from '$components-astro/Menu/MenuTeaser.astro';
import PatioCallout from '$components-astro/PatioCallout.astro';
import TodayStrip from '$components-astro/TodayStrip.astro';
import pubContentService from '$util/PubContent.service';

const home = await pubContentService.home();
---

<BaseLayout
  title="Aurora Colony Pub — Historic Neighborhood Pub in Aurora, OR"
  description="Family-friendly historic pub on old Hwy 99E in Aurora, Oregon. Burgers, breakfast on weekends, happy hour Mon–Fri 3–6, patio in season."
>
  <main>
    <Hero
      title={home.data.title}
      tagline={home.data.tagline}
      heroImage={home.data.heroImage}
      heroImageAlt={home.data.heroImageAlt}
    />
    <FacebookFeedSection />
    <TodayStrip />
    <MenuTeaser />
    <PatioCallout />
    <Gallery limit={9} />
    <AboutTeaser />
  </main>
</BaseLayout>
