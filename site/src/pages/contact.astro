---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hours from '$components-astro/Hours.astro';
import SiteInfo from '$components-astro/SiteInfo.astro';
import Button from '$components-astro/ui/Button.astro';
import Container from '$components-astro/ui/Container.astro';
import Heading from '$components-astro/ui/Heading.astro';
import Section from '$components-astro/ui/Section.astro';
import ContactForm from '$components-svelte/ContactForm';
import PubMap from '$components-svelte/PubMap';
import pubMapService from '$util/PubMap/PubMap.service';
---

<BaseLayout
  title="Contact — Aurora Colony Pub | Aurora, OR"
  description="Address, phone, hours, and a contact form for the Aurora Colony Pub in Aurora, Oregon."
>
  <link slot="head" rel="preconnect" href="https://challenges.cloudflare.com" />
  <link slot="head" rel="preconnect" href="https://a.tile.openstreetmap.org" />
  <main>
    <Section padding="tight">
      <Container size="wide">
        <Heading level={1}>Stop in, or send a note.</Heading>
        <p class="mt-4 max-w-prose font-display text-lg text-foreground/70 md:text-xl">
          We'll get back to you as soon as we can. For the fastest response, give us a call during
          open hours.
        </p>
      </Container>
    </Section>

    <Section>
      <Container size="wide">
        <div class="grid gap-10 md:grid-cols-[1fr_1.2fr] md:gap-16">
          <aside class="rounded-lg border border-foreground/10 bg-foreground/5 p-6 md:p-8">
            <h2 class="font-display text-sm uppercase tracking-[0.18em] text-foreground/60">
              Find us
            </h2>
            <div class="mt-4">
              <SiteInfo />
            </div>
            <h2 class="mt-8 font-display text-sm uppercase tracking-[0.18em] text-foreground/60">
              Hours
            </h2>
            <div class="mt-4">
              <Hours />
            </div>
            <div class="mt-8">
              <Button variant="primary" href={pubMapService.directionsUrl}>Get directions</Button>
            </div>
          </aside>

          <div>
            <h2 class="font-display text-sm uppercase tracking-[0.18em] text-foreground/60">
              Send a note
            </h2>
            <p class="mt-4 max-w-prose text-foreground/80">
              Questions, feedback, or a special event you're planning — we'd love to hear from you.
            </p>
            <div class="mt-6">
              <ContactForm client:idle />
            </div>
          </div>
        </div>
      </Container>
    </Section>

    <Section padding="tight" id="map">
      <Container size="wide">
        <div
          class="aspect-video overflow-hidden rounded-lg border border-foreground/10 bg-foreground/5"
        >
          <PubMap client:visible />
        </div>
        <p class="mt-4 text-center text-sm text-foreground/60">
          Right on old 99E between Salem and Portland.
        </p>
      </Container>
    </Section>
  </main>
</BaseLayout>
