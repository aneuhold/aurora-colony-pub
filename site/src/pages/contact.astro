---
import BaseLayout from '../layouts/BaseLayout.astro';
import Container from '$components-astro/ui/Container.astro';
import Heading from '$components-astro/ui/Heading.astro';
import Section from '$components-astro/ui/Section.astro';
import ContactForm from '$components-svelte/ContactForm';
---

<BaseLayout title="Contact — Aurora Colony Pub" description="Get in touch with Aurora Colony Pub.">
  <!-- Warm the TLS handshake to Turnstile so the script (loaded later by the ContactForm island) downloads fast.
   Scoped to this page since this is where the form lives. -->
  <link slot="head" rel="preconnect" href="https://challenges.cloudflare.com" />
  <main>
    <Section>
      <Container size="narrow">
        <Heading level={1}>Contact us</Heading>
      </Container>
    </Section>
    <ContactForm client:idle />
  </main>
</BaseLayout>
