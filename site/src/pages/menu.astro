---
import BaseLayout from '../layouts/BaseLayout.astro';
import Container from '$components-astro/ui/Container.astro';
import Heading from '$components-astro/ui/Heading.astro';
import Section from '$components-astro/ui/Section.astro';
---

<BaseLayout title="Menu — Aurora Colony Pub" description="Our menu is coming soon.">
  <main>
    <Section>
      <Container size="narrow">
        <Heading level={1}>Menu</Heading>
        <p class="mt-4 text-foreground/70">Coming soon.</p>
      </Container>
    </Section>
  </main>
</BaseLayout>
