{
  "extends": ["../tsconfig.base.json", "astro/tsconfigs/strict"],
  "compilerOptions": {
    "paths": {
      "$components/*": ["./src/components/*"],
      "$util/*": ["./src/util/*"],
      "$styles/*": ["./src/styles/*"]
    }
  },
  "include": [
    ".astro/types.d.ts",
    "src/**/*",
    "astro.config.ts",
    "vitest.config.ts",
    "testUtils/**/*"
  ],
  "exclude": ["dist"]
}
