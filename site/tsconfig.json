{
  "extends": ["../tsconfig.base.json", "astro/tsconfigs/strict"],
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "$components/*": ["src/components/*"],
      "$util/*": ["src/util/*"],
      "$styles/*": ["src/styles/*"]
    }
  },
  "include": [
    ".astro/types.d.ts",
    "src/**/*",
    "astro.config.mjs",
    "vitest.config.ts",
    "testUtils/**/*"
  ],
  "exclude": ["dist"]
}
